# Database Configuration
MONGODB_URI=mongodb+srv://girishkumargundapu:1Fxm79M7ADeiVYtU@cluster0.tvttzmg.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
DATABASE_NAME=attendanceDB

# Server Configuration
PORT=4000
PING_MESSAGE=Attendance Management System API
NODE_ENV=development

# HTTPS Configuration
# Set USE_HTTPS=true to start an HTTPS server using certs/key.pem + certs/cert.pem
# For development, self-signed certificates are sufficient (see HTTPS_SETUP.md)
# Run: npm run generate-certs  — to create the certs automatically
USE_HTTPS=false

# CORS - Additional allowed origins (comma-separated, optional)
# Useful for fixed ngrok/Cloudflare tunnel URLs
# Example: ALLOWED_ORIGINS=https://abc123.ngrok.io,https://myapp.trycloudflare.com
ALLOWED_ORIGINS=

# Security
BCRYPT_SALT_ROUNDS=12
JWT_SECRET=attendancehub-secret-key-2024

# Email Configuration (Gmail SMTP)
GMAIL_USER=girishkumar24122006@gmail.com
GMAIL_PASS=oektrmvlsmjtqxkg
EMAIL_FROM_NAME=AttendanceHub System

# QR Code Configuration
QR_EXPIRY_SECONDS=120

# Geofence Configuration (Dynamic Classroom Location)
# Radius in metres around the teacher's GPS location that counts as "Present"
GEOFENCE_RADIUS_METERS=30
# Attendance window duration in seconds (how long students can scan after teacher starts)
ATTENDANCE_WINDOW_SECONDS=90

# Frontend (Vite) Configuration
# Set VITE_DISABLE_HMR=true when accessing via a tunnel (ngrok/Cloudflare)
# to prevent Hot Module Replacement WebSocket connection errors
VITE_DISABLE_HMR=false

# Leave VITE_APP_BASE_URL empty to use relative /api paths (recommended)
# Only set if your API is on a DIFFERENT origin than the frontend
# Example: VITE_APP_BASE_URL=https://my-api.example.com/api
VITE_APP_BASE_URL=

# App Base URL (used for email links — auto-set by `npm run share`)
# APP_BASE_URL=http://localhost:8080
# STUDENT_APP_BASE_URL=http://localhost:8080
